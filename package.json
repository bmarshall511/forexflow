{
  "name": "fxflow",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:local": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "docs:api": "typedoc",
    "changelog": "auto-changelog --template keepachangelog --commit-limit false --unreleased",
    "postinstall": "lefthook install",
    "site:dev": "pnpm --filter @fxflow/site dev",
    "site:build": "pnpm --filter @fxflow/site build",
    "site:preview": "pnpm --filter @fxflow/site preview"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^9.39.3",
    "@vitest/coverage-v8": "^3.2.4",
    "auto-changelog": "^2.5.0",
    "danger": "^13.0.7",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "knip": "^5.86.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.5",
    "prettier-plugin-tailwindcss": "^0.6",
    "turbo": "^2.5",
    "typedoc": "^0.28.17",
    "typescript": "^5.7",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@prisma/client",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
