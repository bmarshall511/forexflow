# =============================================================================
# FXFlow Cloudflare Worker — Secrets
# =============================================================================
# Copy this file to .dev.vars for local development:
#   cp .dev.vars.example .dev.vars
#
# For production, set these as secrets via wrangler:
#   wrangler secret put WEBHOOK_TOKEN
#   wrangler secret put DAEMON_SECRET
# =============================================================================

# Token appended to the webhook URL: /webhook/{WEBHOOK_TOKEN}
# TradingView sends this in the alert URL to authenticate
WEBHOOK_TOKEN=your-webhook-token

# Secret the daemon sends when connecting via WebSocket
# Must match CF_WORKER_DAEMON_SECRET in the daemon's .env.local
DAEMON_SECRET=your-daemon-secret
