{
  "name": "@fxflow/desktop",
  "version": "0.1.4",
  "description": "FXFlow desktop app for macOS — Electron wrapper for the web UI and daemon",
  "author": "FXFlow",
  "private": true,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "electron:dev": "tsc && electron .",
    "electron:build": "tsc",
    "electron:package": "electron-builder --mac --config electron-builder.yml"
  },
  "dependencies": {
    "@fxflow/shared": "workspace:*",
    "@fxflow/types": "workspace:*",
    "electron-store": "^10",
    "electron-updater": "^6"
  },
  "devDependencies": {
    "electron": "^34",
    "electron-builder": "^25",
    "eslint": "^10.0.3",
    "typescript": "^5.7"
  }
}
