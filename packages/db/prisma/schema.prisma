generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Settings {
  id                    Int      @id @default(1)
  tradingMode           String   @default("practice")
  practiceToken         String? // AES-256-GCM encrypted
  practiceAccountId     String?
  liveToken             String? // AES-256-GCM encrypted
  liveAccountId         String?
  riskPercent           Float    @default(1.0) // Global risk % for position sizing
  onboardingCompleted   Boolean  @default(false)
  deploymentMode        String   @default("local") // "local" | "cloud"
  cloudDaemonUrl        String?  // Remote daemon URL for cloud mode (e.g. https://daemon.railway.app)
  lastResetAt           DateTime? // Timestamp of last trading data/factory reset — gates backfill
  updatedAt             DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  severity  String // "critical" | "warning" | "info"
  source    String // "internet" | "oanda_api" | "oanda_stream" | "daemon" | "ai_analysis" | "trade_condition"
  title     String
  message   String
  metadata  String? // JSON: optional deep-link data e.g. { analysisId, tradeId, conditionId }
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([dismissed, createdAt])
  @@index([severity, createdAt])
  @@index([createdAt])
}

model Trade {
  id                   String       @id @default(uuid())
  source               String // "oanda"
  sourceTradeId        String // OANDA trade/order ID
  status               String // "pending" | "open" | "closed"
  instrument           String // "EUR_USD"
  direction            String // "long" | "short"
  orderType            String? // "LIMIT" | "STOP" | "MARKET" etc.
  entryPrice           Float
  exitPrice            Float?
  stopLoss             Float?
  takeProfit           Float?
  trailingStopDistance  Float?
  initialUnits         Float
  currentUnits         Float
  realizedPL           Float    @default(0)
  unrealizedPL         Float    @default(0)
  financing            Float    @default(0)
  closeReason          String? // "STOP_LOSS_ORDER" | "TAKE_PROFIT_ORDER" etc.
  closeContext         String? // JSON: { breakeven?: boolean, conditionId?: string, originalSL?: number, bufferedSL?: number }
  timeInForce          String? // "GTC" | "GTD"
  gtdTime              String?
  mfe                  Float? // Max Favorable Excursion (pips)
  mae                  Float? // Max Adverse Excursion (pips)
  notes                String?
  timeframe            String? // OANDA granularity code, e.g. "M5", "H1", "D"
  metadata             String? // JSON for source-specific extensibility
  openedAt             DateTime
  closedAt             DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  events               TradeEvent[]
  tags                 TradeTag[]
  analyses             AiAnalysis[]
  conditions           TradeCondition[]
  smartFlowTrades      SmartFlowTrade[]

  @@unique([source, sourceTradeId])
  @@index([status, openedAt])
  @@index([status, closedAt])
  @@index([instrument, status])
  @@index([updatedAt])
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  color     String // hex like "#3B82F6"
  createdAt DateTime   @default(now())
  trades    TradeTag[]
}

model TradeTag {
  id         String   @id @default(uuid())
  tradeId    String
  trade      Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([tradeId, tagId])
  @@index([tradeId])
  @@index([tagId])
}

model TradeEvent {
  id        String   @id @default(uuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  eventType String // "PARTIAL_CLOSE" | "SL_MODIFIED" | "TP_MODIFIED" | "TSL_MODIFIED"
  detail    String // JSON with event-specific data
  createdAt DateTime @default(now())

  @@index([tradeId, createdAt])
}

model ChartLayout {
  id        Int      @id @default(1)
  layout    String   @default("single") // ChartGridLayout
  panels    String   @default("[]") // JSON: ChartPanelConfig[]
  updatedAt DateTime @updatedAt
}

model TVAlertsConfig {
  id                  Int      @id @default(1)
  enabled             Boolean  @default(false)
  webhookToken        String   @default("")
  positionSizePercent Float    @default(1.0) // Legacy — kept for migration compat
  riskPercent         Float    @default(1.0) // Risk-based sizing: % of account risked per trade
  minUnits            Int      @default(1000) // Minimum position size (units) — below this, trade is skipped
  fallbackAtrMultiplier Float  @default(1.5) // ATR multiplier for implied SL when no SL provided
  cooldownSeconds     Int      @default(60)
  maxOpenPositions    Int      @default(3)
  dailyLossLimit      Float    @default(0)
  pairWhitelist       String   @default("[]") // JSON array of instrument strings
  marketHoursFilter   Boolean  @default(true)
  dedupWindowSeconds  Int      @default(5)
  showChartMarkers    Boolean  @default(true)
  soundEnabled        Boolean  @default(true)
  cfWorkerUrl            String   @default("")
  cfWorkerSecret         String   @default("")
  aiFilterEnabled        Boolean  @default(false)
  aiFilterMinConfidence  Int      @default(60)
  updatedAt              DateTime @updatedAt
}

model TVAlertsQualityConfig {
  id                 Int      @id @default(1)
  enabled            Boolean  @default(false)
  minScore           Float    @default(5.0)
  trendFilter        Boolean  @default(true)
  trendWeight        Int      @default(25)
  momentumFilter     Boolean  @default(true)
  momentumWeight     Int      @default(20)
  volatilityFilter   Boolean  @default(true)
  volatilityWeight   Int      @default(20)
  htfFilter          Boolean  @default(true)
  htfWeight          Int      @default(20)
  sessionFilter      Boolean  @default(true)
  sessionWeight      Int      @default(15)
  autoSL             Boolean  @default(true)
  slAtrMultiplier    Float    @default(1.5)
  autoTP             Boolean  @default(true)
  tpRiskRewardRatio  Float    @default(2.0)
  dynamicSizing      Boolean  @default(false)
  highConfThreshold  Float    @default(7.5)
  highConfMultiplier Float    @default(1.25)
  lowConfThreshold   Float    @default(5.5)
  lowConfMultiplier  Float    @default(0.75)
  updatedAt          DateTime @updatedAt
}

model TVAlertsManagementConfig {
  id                        Int      @id @default(1)
  // Breakeven
  breakevenEnabled          Boolean  @default(true)
  breakevenRR               Float    @default(1.0) // Trigger at N:1 profit-to-risk
  breakevenBufferPips       Float    @default(2.0) // Buffer beyond entry
  // Trailing stop
  trailingEnabled           Boolean  @default(true)
  trailingAtrMultiple       Float    @default(1.0) // Trail distance = ATR × this
  trailingStepPips          Float    @default(2.0) // Min move increment
  // Partial close
  partialCloseEnabled       Boolean  @default(true)
  partialCloseStrategy      String   @default("thirds") // "thirds" | "standard" | "none"
  partialCloseRR            Float    @default(1.0) // For "standard" strategy
  partialClosePercent       Float    @default(33.0) // For "standard" strategy
  // Time exit
  timeExitEnabled           Boolean  @default(true)
  timeExitHours             Float    @default(8.0)
  timeExitMinRR             Float    @default(0.5) // Only close if P&L < this R:R
  // Whipsaw detection (UT Bot specific)
  whipsawDetectionEnabled   Boolean  @default(true)
  whipsawWindowHours        Float    @default(4.0) // Lookback window
  whipsawMaxSignals         Int      @default(3) // Max signals before suppression
  whipsawCooldownMinutes    Int      @default(60) // Cooldown after detection
  updatedAt                 DateTime @updatedAt
}

model AiSettings {
  id                     Int      @id @default(1)
  claudeApiKey           String? // AES-256-GCM encrypted
  finnhubApiKey          String? // AES-256-GCM encrypted
  defaultModel           String   @default("claude-sonnet-4-6")
  autoAnalysisJson       String   @default("{}") // JSON: AiAutoAnalysisSettings
  /**
   * When true, the client auto-retries an interrupted analysis once after a
   * 3s cancelable toast (daemon restart, stream stall, timeout). Default off
   * so the user is always in control of retries.
   */
  autoRetryInterrupted   Boolean  @default(false)
  /**
   * Soft monthly cost cap (USD) across all AI analyses. UI warns at 80%,
   * blocks at 100% with override. Null = no cap.
   */
  monthlyBudgetCapUsd    Float?
  /**
   * Max reconciliation ops a single re-run analysis may execute (add/update/
   * remove on existing conditions + immediate actions). Guardrail against a
   * malformed AI response nuking every rule on a trade.
   */
  maxReconciliationOps   Int      @default(20)
  /**
   * JSON payload for re-analysis schedule configuration:
   * { mode, intervalHours?, pipThreshold?, events?, slApproachPips? }
   * See AiReanalysisScheduleConfig in @fxflow/types.
   */
  reanalysisScheduleJson String   @default("{}")
  updatedAt              DateTime @updatedAt
}

model AiAnalysis {
  id                 String   @id @default(uuid())
  tradeId            String
  trade              Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  status             String // "pending" | "running" | "completed" | "partial" | "failed" | "cancelled"
  depth              String // "quick" | "standard" | "deep"
  model              String // claude model ID
  tradeStatus        String // snapshot of trade status at analysis time
  triggeredBy        String   @default("user") // "user" | "auto_pending" | "auto_fill" | "auto_close" | "auto_interval" | "schedule_time" | "schedule_price" | "schedule_event" | "schedule_sl_approach"
  contextSnapshot    String   @default("{}") // JSON: full context sent to Claude
  rawResponse        String? // full streamed Claude text
  sections           String? // JSON: AiAnalysisSections (parsed structured response)
  inputTokens        Int      @default(0)
  outputTokens       Int      @default(0)
  cacheReadTokens    Int      @default(0)
  cacheWriteTokens   Int      @default(0)
  costUsd            Float    @default(0)
  durationMs         Int      @default(0)
  errorMessage       String?
  /**
   * Partial stream text captured when the analysis was cancelled mid-run so
   * the user can see "what Claude got to" before stopping. Null when the
   * analysis completed normally or wasn't cancelled.
   */
  partialStreamText  String?
  /**
   * Set when an analysis was cancelled. Distinct from `updatedAt` because
   * a status transition to `cancelled` may be followed by background writes
   * (e.g., persistence of partial stream).
   */
  cancelledAt        DateTime?
  /**
   * True when Claude's response was cut off by the model's `max_tokens` cap.
   * Analyses with `truncated=true` are saved with status `"partial"` so the UI
   * can surface a banner and offer regeneration. Whatever sections parsed cleanly
   * are persisted; missing sections are rendered as "not generated" placeholders.
   */
  truncated          Boolean  @default(false)
  /**
   * The Anthropic API `stop_reason` field from the final `message_stop` event.
   * Values: `"end_turn"` (normal), `"max_tokens"` (hit cap → truncated),
   * `"stop_sequence"`, `"tool_use"`. Null for older rows and errored runs.
   */
  stopReason         String?
  /**
   * Sections JSON schema version. v1 = flat conditionSuggestions/immediateActions.
   * v2 = includes conditionChanges/immediateActionChanges diff arrays. The
   * UI uses this to pick between legacy and diff-view rendering. Legacy
   * analyses stay at v1; new analyses are written as v2.
   */
  schemaVersion      Int      @default(1)
  /**
   * JSON log of every reconciliation op executed by this analysis on
   * existing conditions and immediate actions: `{ op, target, reason }`.
   * Surfaced in the "Applied automatically" section of the diff view.
   */
  reconciliationLog  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tradeId, createdAt])
  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@index([createdAt])
}

model TradeCondition {
  id                String           @id @default(uuid())
  tradeId           String
  trade             Trade            @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  triggerType       String // "price_reaches" | "price_breaks_above" | "price_breaks_below" | "pnl_pips" | "pnl_currency" | "time_reached" | "duration_hours" | "trailing_stop"
  triggerValue      String // JSON: { price: 1.1050 } | { pips: 20 } | { distance_pips: 15, step_pips: 5 } | etc.
  actionType        String // "close_trade" | "partial_close" | "move_stop_loss" | "move_take_profit" | "cancel_order" | "notify"
  actionParams      String           @default("{}") // JSON: action-specific params
  status            String           @default("active") // "active" | "waiting" | "executing" | "triggered" | "expired" | "cancelled"
  label             String?
  createdBy         String           @default("user") // "user" | "ai"
  analysisId        String? // reference if created from AI analysis
  priority          Int              @default(0) // lower = higher priority for conflict resolution
  parentConditionId String? // For condition chains: child waits until parent triggers
  parentCondition   TradeCondition?  @relation("ConditionChain", fields: [parentConditionId], references: [id], onDelete: SetNull)
  childConditions   TradeCondition[] @relation("ConditionChain")
  expiresAt         DateTime?
  triggeredAt       DateTime?
  /**
   * Set when a user (or re-run reconciliation) has modified this condition
   * after creation. Used by re-run context to tell the AI "the user kept
   * the idea but refined the params" so it can preserve intent.
   */
  lastModifiedAt    DateTime?
  /**
   * Soft-delete timestamp. A condition is removed from active monitoring
   * when this is set, but the row is retained so re-runs can see what the
   * user (or AI reconciliation) rejected and avoid re-proposing it.
   */
  deletedAt         DateTime?
  /**
   * True once the expiry-approaching / expired notification has been
   * emitted for this condition. Prevents duplicate notifications.
   */
  expiredNotified   Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([tradeId, status])
  @@index([status])
  @@index([triggerType, status])
  @@index([parentConditionId])
  @@index([expiresAt])
  @@index([tradeId, deletedAt])
}

/**
 * Lifecycle log for `immediateActions` returned by AI analyses. Unlike
 * `TradeCondition` (which has its own row once applied), immediate actions
 * live inside the analysis JSON — this log tracks whether the user applied,
 * dismissed, or ignored each one so re-runs can reconcile them too.
 */
model AiImmediateActionLog {
  id           String    @id @default(uuid())
  tradeId      String
  analysisId   String
  actionType   String // e.g. "adjust_sl" | "adjust_tp" | "close_trade" | "partial_close"
  actionParams String    @default("{}") // JSON: action-specific params
  status       String    @default("proposed") // "proposed" | "applied" | "dismissed" | "ignored"
  /** Set when the user (or auto-apply) resolved the action. */
  resolvedAt   DateTime?
  /** Short note explaining why (e.g. "auto-applied: confidence=high"). */
  resolvedNote String?
  createdAt    DateTime  @default(now())

  @@index([tradeId, analysisId])
  @@index([tradeId, status])
  @@index([analysisId])
}

// ─── AI Recommendation Tracking ─────────────────────────────────────────────

model AiRecommendationOutcome {
  id                String    @id @default(uuid())
  analysisId        String
  tradeId           String
  recommendedAction String // "hold" | "close" | "adjust" | "reduce" | "watch" | "exit_now"
  winProbability    Float
  qualityScore      Float
  actionFollowed    Boolean   @default(false)
  actionFollowedAt  DateTime?
  tradeOutcome      String? // "win" | "loss" | "breakeven" | "cancelled"
  actualPnl         Float?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([analysisId])
  @@index([tradeId])
  @@index([tradeOutcome, createdAt])
}

// ─── AI Weekly/Monthly Digest ───────────────────────────────────────────────

model AiDigest {
  id           String   @id @default(uuid())
  period       String // "weekly" | "monthly"
  periodStart  DateTime
  periodEnd    DateTime
  status       String   @default("pending") // "pending" | "running" | "completed" | "failed"
  sections     String? // JSON: AiDigestSections
  rawResponse  String?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  durationMs   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([period, periodStart])
  @@index([status])
}

model TVAlertSignal {
  id               String    @id @default(uuid())
  source           String    @default("ut_bot_alerts") // Extensible for future modules
  instrument       String // OANDA format: "EUR_USD"
  direction        String // "buy" | "sell"
  status           String // TVAlertStatus
  rejectionReason  String? // TVAlertRejectionReason
  rawPayload       String // JSON: TVWebhookPayload
  resultTradeId    String? // OANDA source trade ID
  executionDetails String? // JSON: TVExecutionDetails
  isTest           Boolean   @default(false)
  signalTime       DateTime? // TradingView candle close time (from rawPayload.time)
  receivedAt       DateTime
  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  auditEvents      SignalAuditEvent[]

  @@index([instrument, receivedAt])
  @@index([status, receivedAt])
  @@index([source, receivedAt])
  @@index([receivedAt])
  @@index([resultTradeId])
  @@index([processedAt])
}

model SignalAuditEvent {
  id        String        @id @default(uuid())
  signalId  String
  signal    TVAlertSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  stage     String        // "received" | "config_loaded" | "dedup_checked" | "validated" | "executing" | "executed" | "rejected" | "failed"
  detail    String        // JSON: { reason?, direction?, instrument?, duration_ms?, raw_payload?, ... }
  timestamp DateTime      @default(now())

  @@index([signalId, timestamp])
}

// ─── Supply & Demand Zones ──────────────────────────────────────────────────

model SupplyDemandZone {
  id              String   @id @default(uuid())
  instrument      String // "EUR_USD"
  timeframe       String // "H1"
  type            String // "demand" | "supply"
  formation       String // "DBR" | "RBR" | "RBD" | "DBD"
  proximalLine    Float
  distalLine      Float
  width           Float
  widthPips       Float
  baseStartTime   Int // Unix seconds
  baseEndTime     Int // Unix seconds
  baseCandles     Int
  baseStartIndex  Int
  baseEndIndex    Int
  scoreStrength   Float    @default(0)
  scoreTime       Float    @default(0)
  scoreFreshness  Float    @default(0)
  scoreTotal      Float    @default(0)
  scoresJson      String   @default("{}") // Full ZoneScores JSON
  riskRewardJson  String   @default("{}") // ZoneRiskReward JSON
  status          String   @default("active") // "active" | "tested" | "invalidated"
  penetrationPct  Float    @default(0)
  testCount       Int      @default(0)
  firstDetectedAt DateTime @default(now())
  lastConfirmedAt DateTime @default(now())
  lastScoredAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([instrument, timeframe, baseStartTime, baseEndTime, type])
  @@index([instrument, timeframe, status])
  @@index([instrument, timeframe, scoreTotal])
  @@index([status])
  @@index([lastConfirmedAt])
  @@index([lastScoredAt])
}

model ZoneSettings {
  id           Int      @id @default(1)
  settingsJson String   @default("{}") // JSON: ZoneDisplaySettings
  updatedAt    DateTime @updatedAt
}

model DetectedTrend {
  id               String   @id @default(uuid())
  instrument       String // "EUR_USD"
  timeframe        String // "H1"
  direction        String? // "up" | "down" | null (range)
  status           String // "forming" | "confirmed" | "terminated"
  swingPointsJson  String   @default("[]") // JSON: SwingPoint[]
  segmentsJson     String   @default("[]") // JSON: TrendSegment[]
  controllingSwing String? // JSON: SwingPoint | null
  currentPrice     Float
  candlesAnalyzed  Int
  computedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([instrument, timeframe, computedAt])
  @@index([instrument, timeframe, status])
}

model CurveSnapshot {
  id            String   @id @default(uuid())
  instrument    String
  timeframe     String
  supplyDistal  Float
  demandDistal  Float
  highThreshold Float
  lowThreshold  Float
  position      String // "high" | "middle" | "low" | "above" | "below"
  currentPrice  Float
  computedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([instrument, timeframe, computedAt])
}

model TrendSettings {
  id           Int      @id @default(1)
  settingsJson String   @default("{}") // JSON: TrendDisplaySettings
  updatedAt    DateTime @updatedAt
}

// ─── Trade Finder ──────────────────────────────────────────────────────────

model TradeFinderConfig {
  id                            Int      @id @default(1)
  enabled                       Boolean  @default(false)
  minScore                      Float    @default(7.0)
  maxEnabledPairs               Int      @default(10)
  approachingAtrMultiple        Float    @default(1.5) // Distance in ATR multiples to mark "approaching"
  autoTradeEnabled              Boolean  @default(false)
  autoTradeMinScore             Float    @default(11.0) // Separate threshold for auto-trade
  autoTradeMaxConcurrent        Int      @default(3) // Max pending auto-placed orders at once
  autoTradeMaxDaily             Int      @default(5) // Max auto-trades per 24h
  autoTradeMaxRiskPercent       Float    @default(6.0) // Total risk cap across auto-trades
  autoTradeMinRR               Float    @default(2.0) // Minimum R:R ratio for auto-trade (e.g. 2.0 = 2:1)
  autoTradeCancelOnInvalidation Boolean  @default(true) // Cancel pending auto-orders when zone invalidated
  smartSizing                   Boolean  @default(true) // Scale position size down by score (never up)
  entryConfirmation             Boolean  @default(true) // Wait for confirmation candle pattern before placing
  confirmationTimeout           Int      @default(6) // Max candles to wait for confirmation before fallback
  breakevenEnabled              Boolean  @default(true) // Move SL to entry at 1:1 R:R
  partialCloseEnabled           Boolean  @default(true) // Close portion at partial target
  partialClosePercent           Float    @default(50) // % of position to close at partial target
  partialCloseRR                Float    @default(1.5) // R:R target for partial close
  trailingStopEnabled           Boolean  @default(true) // Trail SL behind recent candles
  trailingStopCandles           Int      @default(3) // Number of candles to trail behind
  timeExitEnabled               Boolean  @default(false) // Close if no progress after N candles
  timeExitCandles               Int      @default(20) // Max candles before time-based exit
  partialExitStrategy           String   @default("standard") // "standard" | "thirds"
  shadowMode                    Boolean  @default(false) // Shadow mode: run logic but don't place real orders
  entryDepthPercent             Float    @default(25) // How deep into zone body (0=proximal, 25=25%, 50=50%)
  sessionPreference             String   @default("kill_zones") // "kill_zones" | "all_sessions" | "conservative"
  aiManagedEnabled              Boolean  @default(true) // Defer to AI conditions when available for filled trades
  pairsJson                     String   @default("[]") // JSON: TradeFinderPairConfig[]
  dimensionWeightsJson          String?  // JSON: TradeFinderDimensionWeights (adaptive learning)
  updatedAt                     DateTime @updatedAt
}

model TradeFinderSetup {
  id               String   @id @default(uuid())
  instrument       String
  direction        String // "long" | "short"
  timeframeSet     String // "hourly" | "daily" | "weekly" | "monthly"
  status           String   @default("active") // "active" | "approaching" | "placed" | "invalidated" | "expired"
  entryPrice       Float
  stopLoss         Float
  takeProfit       Float
  riskPips         Float
  rewardPips       Float
  rrRatio          String // e.g. "2.5:1"
  positionSize     Float
  scoresJson       String   @default("{}") // JSON: TradeFinderScoreBreakdown
  scoreTotal       Float    @default(0)
  zoneJson         String   @default("{}") // JSON: ZoneData (the driving LTF zone)
  trendJson        String? // JSON: TrendData snapshot
  curveJson        String? // JSON: CurveData snapshot
  distanceToEntry  Float    @default(0) // pips from current price to entry
  resultSourceId   String? // OANDA trade/order ID if placed
  autoPlaced       Boolean  @default(false) // Whether auto-traded
  placedAt         DateTime? // When auto-trade placed the order (for daily cap)
  lastSkipReason   String? // Why auto-trade was most recently skipped
  confirmationPattern       String? // Entry confirmation pattern detected (e.g. "engulfing", "pin_bar")
  confirmationCandlesWaited Int      @default(0) // How many scan cycles spent waiting for confirmation
  breakevenMoved     Boolean  @default(false) // SL moved to breakeven
  partialTaken       Boolean  @default(false) // Partial profit taken
  managementLog      String?  // JSON array of management actions taken
  arrivalSpeed       String?  // "controlled" | "displacement" | "sweep"
  theoreticalOutcomeJson String? // JSON: TradeFinderTheoreticalOutcome
  detectionSession   String?  // Trading session at detection: "london_open" | "ny_open" | etc
  detectedAt       DateTime @default(now())
  lastUpdatedAt    DateTime @default(now())
  expiredAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([instrument, status])
  @@index([status, scoreTotal])
  @@index([status, detectedAt])
  @@index([autoPlaced, placedAt])
  @@index([placedAt])
}

model TradeFinderPerformance {
  id           String   @id @default(uuid())
  dimension    String   // "overall" | "timeframe" | "instrument" | "score_range"
  dimensionKey String?  // e.g. "hourly", "EUR_USD", "10-12" (null for overall)
  periodStart  DateTime
  periodEnd    DateTime
  totalSetups  Int      @default(0)
  placed       Int      @default(0)
  filled       Int      @default(0)
  wins         Int      @default(0)
  losses       Int      @default(0)
  breakevens   Int      @default(0)
  totalPL      Float    @default(0)
  avgRR        Float    @default(0) // Average actual R:R achieved
  expectedRR   Float    @default(0) // Average expected R:R at placement
  profitFactor Float    @default(0)
  expectancy   Float    @default(0)
  maxDrawdown  Float    @default(0)
  updatedAt    DateTime @updatedAt

  @@index([dimension, dimensionKey, periodStart])
  @@index([dimension, periodStart])
}

// ─── AI Trader ──────────────────────────────────────────────────────────────

model AiTraderConfig {
  id                     Int      @id @default(1)
  enabled                Boolean  @default(false)
  operatingMode          String   @default("manual") // "manual" | "semi_auto" | "full_auto"
  scanIntervalMinutes    Int      @default(30)
  confidenceThreshold    Int      @default(70) // For semi/full auto execution
  minimumConfidence      Int      @default(60) // Below this, never suggest
  maxConcurrentTrades    Int      @default(5)
  pairWhitelist          String   @default("[]") // JSON: string[]
  enabledProfiles        String   @default("{}") // JSON: Record<AiTraderProfile, boolean>
  enabledTechniques      String   @default("{}") // JSON: Record<AiTraderTechnique, boolean>
  managementConfig       String   @default("{}") // JSON: AiTraderManagementConfig
  reEvalIntervalMinutes  Int      @default(60)
  dailyBudgetUsd         Float    @default(5.0)
  monthlyBudgetUsd       Float    @default(100.0)
  scanModel              String   @default("claude-haiku-4-5-20251001")
  decisionModel          String   @default("claude-sonnet-4-6")
  /// Enable multi-agent analysis (analyst briefs → bull/bear debate → judge).
  /// When false, falls back to single Sonnet Tier 3 call.
  multiAgentEnabled      Boolean  @default(true)
  fredApiKey             String?  // AES-256-GCM encrypted
  alphaVantageApiKey     String?  // AES-256-GCM encrypted
  updatedAt              DateTime @updatedAt
}

model AiTraderOpportunity {
  id                  String    @id @default(uuid())
  instrument          String
  direction           String    // "long" | "short"
  profile             String    // "scalper" | "intraday" | "swing" | "news"
  status              String    @default("detected")
  confidence          Int       @default(0) // 0-100
  scoresJson          String    @default("{}") // JSON: AiTraderScoreBreakdown
  entryPrice          Float
  stopLoss            Float
  takeProfit          Float
  riskPips            Float
  rewardPips          Float
  riskRewardRatio     Float
  positionSize        Int       @default(0)
  regime              String?   // AiTraderMarketRegime
  session             String?   // AiTraderSession
  primaryTechnique    String?   // AiTraderTechnique
  entryRationale      String?   // AI-generated explanation
  technicalSnapshot   String    @default("{}") // JSON: indicators, zones, structure
  fundamentalSnapshot String    @default("{}") // JSON: macro, calendar, COT
  sentimentSnapshot   String    @default("{}") // JSON: news sentiment
  tier2Response       String?   // Haiku scan response
  tier2Model           String?   // Claude model used for scan
  tier2InputTokens     Int       @default(0)
  tier2OutputTokens    Int       @default(0)
  tier2Cost            Float     @default(0)
  /// Tier 2's own confidence score (0-100) BEFORE Tier 3 gets involved.
  /// Distinct from `confidence` which holds the final Tier 3 score. Used to
  /// audit Haiku's quick-filter accuracy separately from Sonnet's decision.
  tier2Confidence      Int?
  /// Whether Tier 2 returned `pass: true` (i.e. forwarded to Tier 3).
  tier2Passed          Boolean?
  /// Timestamp Tier 2 completed (not Tier 3). Helpful for per-tier latency
  /// breakdowns and for distinguishing Tier 2 rejections from Tier 3 ones
  /// in post-mortem queries.
  tier2DecidedAt       DateTime?
  /// Multi-agent debate data (when multiAgentEnabled)
  technicalBrief      String?   // Technical analyst brief
  macroRiskBrief      String?   // Macro/risk analyst brief
  bullCase            String?   // Bull advocate argument
  bearCase            String?   // Bear advocate counter-argument
  debateCost          Float     @default(0)  // Combined cost of briefs + bull + bear
  debateInputTokens   Int       @default(0)
  debateOutputTokens  Int       @default(0)
  tier3Response       String?   // Deep analysis response (judge decision in multi-agent mode)
  tier3Model          String?   // Claude model used for decision
  tier3InputTokens    Int       @default(0)
  tier3OutputTokens   Int       @default(0)
  tier3Cost           Float     @default(0)
  resultTradeId       String?   // FK to Trade.id once placed
  resultSourceId      String?   // OANDA order/trade ID
  realizedPL          Float?    // Final P&L once closed
  outcome             String?   // "win" | "loss" | "breakeven"
  managementLog       String    @default("[]") // JSON: AiTraderManagementAction[]
  detectedAt          DateTime  @default(now())
  suggestedAt         DateTime?
  placedAt            DateTime?
  filledAt            DateTime?
  closedAt            DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([instrument, status])
  @@index([status, confidence])
  @@index([profile, status])
  @@index([detectedAt])
  @@index([status, detectedAt])
  @@index([resultTradeId])
}

model AiTraderMarketData {
  id        String   @id @default(uuid())
  dataType  String   // AiTraderMarketDataType
  dataKey   String   // e.g. "USD", "EUR_USD", "NFP", "global"
  data      String   // JSON payload
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([dataType, dataKey, expiresAt])
  @@index([dataType, expiresAt])
}

/// Tier 1 signals that almost passed the filter but didn't. Persisted so we
/// can tune Tier 1 thresholds from real data instead of the scanner's
/// in-memory ring buffer (which evaporates on daemon restart). Fills the gap
/// flagged in the original SmartFlow + EdgeFinder audit — near-miss data was
/// previously only surfaced in the `ai_trader_scan_progress` WS broadcast
/// and lost at the end of each scan.
model AiTraderNearMiss {
  id             String   @id @default(uuid())
  instrument     String
  direction      String   // "long" | "short"
  profile        String   // "scalper" | "intraday" | "swing" | "news"
  /// Tier 1 confluence score (0-100) of the would-be signal.
  confidence     Int
  /// Which filter blocked the signal ("spread", "rr", "htf", "rsi", "low_vol",
  /// "no_signal", "low_confluence", ...).
  blockingFilter String
  /// Human-readable reason from the filter breakdown.
  reason         String?
  /// Full Tier1NearMiss payload as captured during the scan, for post-mortem.
  metadata       String   @default("{}")
  detectedAt     DateTime @default(now())

  @@index([detectedAt])
  @@index([instrument, detectedAt])
  @@index([profile, detectedAt])
  @@index([blockingFilter, detectedAt])
}

/// Post-trade reflection generated by AI after an EdgeFinder trade closes.
/// Captures qualitative lessons (what the thesis was, what happened, what to
/// change) and injects them into future Judge prompts as "experience memory".
model AiTraderReflection {
  id               String   @id @default(uuid())
  /// FK to AiTraderOpportunity — one reflection per closed trade
  opportunityId    String   @unique
  instrument       String
  direction        String   // "long" | "short"
  profile          String   // AiTraderProfile
  confidence       Int      // Final Tier 3 confidence at decision time
  outcome          String   // "win" | "loss" | "breakeven"
  realizedPL       Float
  entryRationale   String?  // Original trade thesis from Tier 3
  /// AI-generated narrative of what happened and why (3-5 sentences)
  reflection       String
  /// Actionable bullet points for similar future trades
  lessonsLearned   String
  primaryTechnique String?  // AiTraderTechnique
  regime           String?  // AiTraderMarketRegime
  session          String?  // AiTraderSession
  model            String?  // Claude model that generated the reflection
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cost             Float    @default(0)
  closedAt         DateTime
  createdAt        DateTime @default(now())

  @@index([instrument, profile, createdAt])
  @@index([profile, outcome, createdAt])
  @@index([createdAt])
}

// ─── Price Alerts ────────────────────────────────────────────────────────────

model PriceAlert {
  id           String    @id @default(cuid())
  instrument   String // e.g., "EUR_USD"
  direction    String // "above" | "below"
  targetPrice  Float
  currentPrice Float // price when alert was created
  label        String?
  status       String    @default("active") // "active" | "triggered" | "expired" | "cancelled"
  repeating    Boolean   @default(false) // if true, re-arms after trigger
  triggeredAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([instrument, status])
  @@index([expiresAt])
}

// ─── Source Priority ────────────────────────────────────────────────────

model SourcePriorityConfig {
  id                      Int      @id @default(1)
  enabled                 Boolean  @default(true)
  mode                    String   @default("manual") // "manual" | "auto_select"
  priorityOrder           String   @default("[\"trade_finder\",\"tv_alerts\",\"ai_trader\",\"smart_flow\"]") // JSON: string[]
  autoSelectWindowDays    Int      @default(30)
  autoSelectRecalcMinutes Int      @default(60)
  updatedAt               DateTime @updatedAt
}

model SourcePriorityLog {
  id               String   @id @default(uuid())
  instrument       String
  requestingSource String
  existingSource   String?
  existingTradeId  String?
  action           String // "placed" | "blocked_open" | "blocked_pending" | "replaced_pending" | "blocked_manual"
  reason           String
  createdAt        DateTime @default(now())

  @@index([instrument, createdAt])
  @@index([requestingSource, createdAt])
  @@index([createdAt])
}

// ─── SmartFlow ──────────────────────────────────────────────────────────

model SmartFlowSettings {
  id                         Int      @id @default(1)
  enabled                    Boolean  @default(false)
  maxConcurrentTrades        Int      @default(3)
  maxMarginPercent           Float    @default(40.0)
  defaultPreset              String   @default("steady_growth") // SmartFlowPreset
  correlationWarningEnabled  Boolean  @default(true)
  maxCorrelatedPairs         Int      @default(2)
  aiBudgetDailyUsd           Float    @default(1.0)
  aiBudgetMonthlyUsd         Float    @default(20.0)
  aiDefaultModel             String   @default("claude-haiku-4-5-20251001")
  defaultMaxDrawdownPercent  Float    @default(5.0)
  defaultMaxHoldHours        Int      @default(168) // 7 days
  defaultMaxFinancingUsd     Float    @default(50.0)
  spreadProtectionEnabled    Boolean  @default(true)
  spreadProtectionMultiple   Float    @default(3.0) // trigger when spread > avg * this
  shadowMode                 Boolean  @default(false)
  // Scanner — autonomous market scanning
  scannerEnabled             Boolean  @default(false)
  scanIntervalMinutes        Int      @default(15)
  operatingMode              String   @default("full_auto") // "manual" | "semi_auto" | "full_auto"
  autoTradeMinScore          Int      @default(60) // 0-100, semi_auto score threshold
  scanModesJson              String   @default("{}") // Record<SmartFlowScanMode, boolean>
  pairWhitelistJson          String   @default("[]") // string[] — empty = all majors+crosses
  maxDailyScans              Int      @default(50)
  maxDailyAutoTrades         Int      @default(5)
  preferredPreset            String   @default("auto") // "auto" = regime-based, or specific preset
  scannerEntryMode           String   @default("optimal") // "market" | "optimal" | "smart_entry"
  sessionRestriction         String   @default("kill_zones") // "kill_zones" | "extended" | "any"
  newsBufferMinutes          Int      @default(60)
  circuitBreakerConsecLosses Int      @default(3)
  circuitBreakerConsecPause  Int      @default(120) // pause minutes after consecutive losses
  circuitBreakerDailyLosses  Int      @default(4)
  circuitBreakerDailyDD      Float    @default(3.0) // max daily drawdown percent before pause
  updatedAt                  DateTime @updatedAt
}

model SmartFlowConfig {
  id                       String   @id @default(uuid())
  instrument               String
  name                     String
  direction                String // "long" | "short"
  preset                   String   @default("steady_growth") // SmartFlowPreset
  isActive                 Boolean  @default(true)
  // Entry
  entryMode                String   @default("market") // "market" | "smart_entry"
  entryPrice               Float?
  entryConditionsJson      String?  // JSON: SmartFlowEntryCondition[]
  entryExpireHours         Int?
  // Risk
  positionSizeMode         String   @default("risk_percent") // "risk_percent" | "fixed_units" | "fixed_lots" | "kelly"
  positionSizeValue        Float    @default(1.0)
  stopLossAtrMultiple      Float?   // e.g. 0.75 = 0.75x ATR
  takeProfitAtrMultiple    Float?   // e.g. 1.5 = 1.5x ATR
  stopLossPips             Float?   // manual override (if set, ignores ATR)
  takeProfitPips           Float?   // manual override (if set, ignores ATR)
  minRiskReward            Float    @default(1.5)
  // Breakeven
  breakevenEnabled         Boolean  @default(true)
  breakevenAtrMultiple     Float    @default(0.75) // trigger at this * ATR profit
  breakevenBufferPips      Float    @default(2.0)  // SL = entry + buffer (covers spread)
  // Trailing stop
  trailingEnabled          Boolean  @default(false)
  trailingAtrMultiple      Float    @default(0.5)  // trail distance = this * ATR
  trailingActivationAtr    Float    @default(0.75) // only start after this * ATR profit
  // Partial close
  partialCloseRulesJson    String?  // JSON: SmartFlowPartialCloseRule[] (ATR-relative)
  // Safety nets
  maxDrawdownPercent       Float?   // close if account drawdown exceeds this
  maxDrawdownPips          Float?   // close if trade drawdown exceeds pips
  maxHoldHours             Int?     // close/notify after this many hours
  maxFinancingUsd          Float?   // close if swap costs exceed this
  // Session management
  sessionAwareManagement   Boolean  @default(true)
  offSessionBehavior       String   @default("widen_thresholds") // "widen_thresholds" | "pause_management" | "normal"
  weekendCloseEnabled      Boolean  @default(false)
  // News protection
  newsProtectionEnabled    Boolean  @default(true)
  newsProtectionMinutes    Int      @default(30)
  // Recovery mode (DCA) — advanced only
  recoveryEnabled          Boolean  @default(false)
  recoveryMaxLevels        Int      @default(3)
  recoveryAtrInterval      Float    @default(0.5) // add every this * ATR against
  recoverySizeMultiplier   Float    @default(0.5) // each add = initial * this
  recoveryTpAtrMultiple    Float    @default(0.3) // TP from average entry
  // AI Assist
  aiMode                   String   @default("auto_selective") // "off" | "suggest" | "auto_selective" | "full_auto"
  aiMonitorIntervalHours   Int      @default(1)
  aiModel                  String?
  aiActionTogglesJson      String   @default("{\"moveSL\":true,\"moveTP\":true,\"breakeven\":true,\"partialClose\":true,\"closeProfit\":true,\"preemptiveSafetyClose\":true,\"cancelEntry\":true,\"adjustTrail\":true}") // JSON: SmartFlowAiActionToggles
  aiConfidenceThresholdsJson String @default("{}") // JSON: SmartFlowAiConfidenceThresholds
  aiMaxActionsPerDay       Int      @default(10)
  aiCooldownAfterManualMins Int     @default(120)
  aiGracePeriodMins        Int      @default(15)
  // Meta
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  trades                   SmartFlowTrade[]

  @@index([instrument, isActive])
  @@index([instrument, direction])
}

model SmartFlowTrade {
  id                     String    @id @default(uuid())
  configId               String
  config                 SmartFlowConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  tradeId                String?   // FK to Trade.id once placed
  trade                  Trade?    @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  sourceTradeId          String?   // OANDA trade ID
  status                 String    @default("waiting_entry") // "waiting_entry" | "pending" | "open" | "managing" | "closing" | "closed"
  entryPrice             Float?
  currentPhase           String    @default("entry") // "entry" | "breakeven" | "trailing" | "partial" | "recovery" | "safety_net" | "target"
  // Management state
  breakevenTriggered     Boolean   @default(false)
  trailingActivated      Boolean   @default(false)
  partialCloseLogJson    String    @default("[]") // JSON: SmartFlowPartialCloseEntry[]
  managementLogJson      String    @default("[]") // JSON: SmartFlowManagementEntry[]
  recoveryLevel          Int       @default(0)    // current DCA level (0 = initial only)
  recoveryTradeIds       String    @default("[]") // JSON: string[] of additional OANDA trade IDs
  /// Last management rule that fired (breakeven, trailing_moved, partial_close, safety_net, etc.)
  lastManagementAction   String?
  // Time estimation
  estimatedHours         Float?
  estimatedLow           Float?
  estimatedHigh          Float?
  // Safety net
  safetyNetTriggered     String?   // "max_drawdown" | "max_hold" | "max_financing" | "margin_warning" | null
  financingAccumulated   Float     @default(0)
  // Spread tracking
  entrySpread            Float?    // spread at time of entry
  avgSpread              Float?    // rolling avg spread for this instrument
  // Market context at placement — captured ONCE, at entry, for post-mortem
  // feedback loops ("did SmartFlow trades perform better in trending vs
  // ranging regimes?"). Distinct from `SmartFlowOpportunity.regime` which
  // is captured during scanning BEFORE placement.
  atrAtPlacement         Float?
  regimeAtPlacement      String?   // "trending" | "ranging" | "volatile" | "low_volatility"
  // AI assist
  aiActionsToday         Int       @default(0)
  aiLastActionAt         DateTime?
  aiTotalCost            Float     @default(0)
  aiTotalInputTokens     Int       @default(0)
  aiTotalOutputTokens    Int       @default(0)
  aiSuggestionsLogJson   String    @default("[]") // JSON: SmartFlowAiSuggestion[]
  lastManualOverrideAt   DateTime?
  // Timestamps
  createdAt              DateTime  @default(now())
  closedAt               DateTime?
  updatedAt              DateTime  @updatedAt

  @@index([configId])
  @@index([status])
  @@index([status, createdAt])
  @@index([configId, status])
  @@index([tradeId])
  @@index([sourceTradeId])
}

model SmartFlowTimeEstimate {
  id          String   @id @default(uuid())
  instrument  String
  preset      String
  direction   String
  targetPips  Float
  actualHours Float
  outcome     String // "win" | "loss" | "safety_net"
  closedAt    DateTime
  createdAt   DateTime @default(now())

  @@index([instrument, preset, direction])
  @@index([closedAt])
}

model SmartFlowActivityLog {
  id         String   @id @default(uuid())
  type       String // SmartFlowActivityType
  message    String
  detail     String?
  severity   String   @default("info") // "info" | "success" | "warning" | "error"
  instrument String?
  tradeId    String?
  configId   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([configId, createdAt])
  @@index([instrument, createdAt])
}

model SmartFlowOpportunity {
  id               String   @id @default(uuid())
  instrument       String
  direction        String // "long" | "short"
  scanMode         String // SmartFlowScanMode: "trend_following" | "mean_reversion" | "breakout" | "session_momentum"
  status           String   @default("detected") // SmartFlowOpportunityStatus
  score            Int      @default(0) // 0-100 composite score
  scoresJson       String   @default("{}") // SmartFlowOpportunityScores breakdown
  regime           String? // AiTraderMarketRegime
  session          String? // ForexSession
  preset           String? // SmartFlowPreset auto-selected
  entryPrice       Float
  stopLoss         Float
  takeProfit       Float
  riskPips         Float
  rewardPips       Float
  riskRewardRatio  Float
  positionSize     Int      @default(0)
  reasons          String   @default("[]") // string[] — why this signal was generated
  filterResults    String   @default("{}") // Record<string, { passed: boolean; reason?: string }>
  resultConfigId   String? // SmartFlowConfig.id if auto-created
  resultTradeId    String? // OANDA trade ID if placed
  realizedPL       Float?
  outcome          String? // "win" | "loss" | "breakeven"
  expiresAt        DateTime?
  detectedAt       DateTime @default(now())
  placedAt         DateTime?
  closedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([instrument, status])
  @@index([status, score])
  @@index([scanMode, status])
  @@index([detectedAt])
}

// ─── Authentication ─────────────────────────────────────────────────────────

model AuthPin {
  id             String    @id @default(cuid())
  pinHash        String // bcrypt hash of PIN
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  sessionExpiry  Int       @default(86400) // seconds (default 24h)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  device    String? // user-agent for session management UI
  createdAt DateTime @default(now())
}

model EconomicEvent {
  id        String   @id @default(cuid())
  title     String
  currency  String   // e.g., "USD", "EUR"
  impact    String   // "low" | "medium" | "high"
  actual    String?
  forecast  String?
  previous  String?
  timestamp DateTime // when the event occurs
  fetchedAt DateTime @default(now())

  @@unique([title, timestamp])
  @@index([timestamp])
  @@index([currency, timestamp])
  @@index([impact, timestamp])
}

model AiTraderStrategyPerformance {
  id           String   @id @default(uuid())
  profile      String   // AiTraderProfile
  instrument   String?  // null = all instruments
  session      String?  // null = all sessions
  technique    String?  // Primary technique, null = all
  periodStart  DateTime
  periodEnd    DateTime
  totalTrades  Int      @default(0)
  wins         Int      @default(0)
  losses       Int      @default(0)
  breakevens   Int      @default(0)
  totalPL      Float    @default(0)
  avgRR        Float    @default(0)
  profitFactor Float    @default(0)
  expectancy   Float    @default(0)
  maxDrawdown  Float    @default(0)
  updatedAt    DateTime @updatedAt

  @@index([profile, instrument, periodStart])
  @@index([profile, periodStart])
}
