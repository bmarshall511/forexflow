---
import Base from "../layouts/Base.astro"
import Nav from "../components/Nav.astro"
import Hero from "../components/Hero.astro"
import StatsCounter from "../components/StatsCounter.astro"
import FeatureShowcase from "../components/FeatureShowcase.astro"
import ArchitectureDiagram from "../components/ArchitectureDiagram.astro"
import GovernanceSection from "../components/GovernanceSection.astro"
