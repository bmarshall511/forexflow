---
import SectionHeading from "./SectionHeading.astro"

const steps = [
  {
    step: "1",
    title: "Clone and install",
    code: `git clone https://github.com/bmarshall511/forexflow.git
cd forexflow
pnpm install`,
  },
  {
    step: "2",
    title: "Generate Prisma client",
    code: `pnpm --filter @fxflow/db db:generate`,
  },
  {
    step: "3",
    title: "Configure environment",
    code: `# Single root env file — no per-app duplicates
cat > .env.local <<'EOF'
DATABASE_URL=file:../../data/fxflow.db
ENCRYPTION_KEY=
NEXT_PUBLIC_DAEMON_REST_URL=http://localhost:4100
NEXT_PUBLIC_DAEMON_URL=ws://localhost:4100
EOF

# Generate an ENCRYPTION_KEY and paste it into .env.local
node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`,
  },
  {
    step: "4",
    title: "Initialize database and start",
    code: `mkdir -p data
pnpm --filter @fxflow/db db:migrate
pnpm dev`,
  },
]
---

<section id="quickstart" class="py-24" aria-label="Quick start">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      title="Get started in 4 steps"
      subtitle="From clone to running in under 5 minutes. Requires Node.js >= 22 and pnpm >= 10."
    />

    <div class="mx-auto max-w-3xl space-y-6">
      {
        steps.map((item) => (
          <div class="rounded-xl border border-border bg-bg-surface">
            <div class="flex items-center gap-3 border-b border-border px-5 py-3">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent text-xs font-bold text-white">
                {item.step}
              </span>
              <h3 class="text-sm font-semibold">{item.title}</h3>
            </div>
            <div class="overflow-x-auto p-4">
              <pre class="text-sm leading-relaxed text-text-muted font-mono"><code>{item.code}</code></pre>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mx-auto mt-8 max-w-3xl text-center">
      <p class="text-sm text-text-muted">
        Open <code class="rounded bg-bg-elevated px-1.5 py-0.5 text-xs font-mono">http://localhost:3000/settings/oanda</code> to connect your OANDA account. See the
        <a
          href="https://github.com/bmarshall511/forexflow#configuration"
          class="text-accent underline underline-offset-2 hover:text-accent-hover"
          target="_blank"
          rel="noopener noreferrer"
        >
          full configuration guide
        </a> for all options.
      </p>
    </div>
  </div>
</section>
