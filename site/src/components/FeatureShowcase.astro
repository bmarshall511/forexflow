    icon: icons.dashboard,
    color: "accent",
    bullets: [
      "Live P&L, equity, margin, drawdown, and NAV",
      "Open positions with sub-second price streaming",
      "AI insights card, automation status tiles",
      "Notification center with deep-linked actions",
    ],
  },
