---
const base = "/forexflow"
---

<div id="hero-sentinel" class="absolute top-0 h-1 w-full"></div>

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28" aria-label="Hero">
  <!-- Gradient background -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-1/2 left-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-20 blur-3xl"
      style="background: radial-gradient(circle, oklch(0.5 0.2 285), transparent 70%)"
    >
    </div>
    <div
      class="absolute top-1/4 right-1/4 h-[400px] w-[400px] rounded-full opacity-10 blur-3xl"
      style="background: radial-gradient(circle, oklch(0.6 0.15 260), transparent 70%)"
    >
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-6 text-center">
    <!-- Badges -->
    <div class="mb-8 flex flex-wrap items-center justify-center gap-2">
      <a href="https://github.com/bmarshall511/forexflow/actions/workflows/ci.yml" target="_blank" rel="noopener noreferrer">
        <img src="https://github.com/bmarshall511/forexflow/actions/workflows/ci.yml/badge.svg" alt="CI" loading="lazy" />
      </a>
      <a href="https://github.com/bmarshall511/forexflow/actions/workflows/security.yml" target="_blank" rel="noopener noreferrer">
        <img src="https://github.com/bmarshall511/forexflow/actions/workflows/security.yml/badge.svg" alt="Security" loading="lazy" />
      </a>
      <img src="https://img.shields.io/badge/License-AGPL--3.0-blue.svg" alt="License: AGPL-3.0" loading="lazy" />
      <img src="https://img.shields.io/badge/TypeScript-5.7-blue.svg" alt="TypeScript" loading="lazy" />
    </div>

    <!-- Headline -->
    <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
      A forex trading platform
      <br />
      <span class="bg-gradient-to-r from-accent to-blue bg-clip-text text-transparent">
        built with AI — and powered by it
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted sm:text-xl">
      Self-hosted. Real-time. Open source. Built solo in ~3 weeks with Claude Code — then Claude was
      integrated as a runtime feature for live trade analysis.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#quickstart"
        class="inline-flex items-center gap-2 rounded-xl bg-accent px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-hover"
      >
        Get Started
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
      <a
        href="https://github.com/bmarshall511/forexflow"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-border bg-bg-surface px-6 py-3 text-sm font-semibold text-text transition-colors hover:bg-bg-hover"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Disclaimer -->
    <p class="mt-12 text-xs leading-relaxed text-text-faint">
      ForexFlow is provided as-is for educational and personal use. It is not financial advice.
      Trading forex involves significant risk of loss. Use at your own risk.
    </p>
  </div>
</section>
