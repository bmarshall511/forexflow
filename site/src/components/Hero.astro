---
const base = "/forexflow"
---

<div id="hero-sentinel" class="absolute top-0 h-1 w-full"></div>

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28" aria-label="Hero">
  <!-- Gradient background -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="hero-glow absolute top-1/2 left-1/2 h-[900px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-25 blur-3xl"
      style="background: radial-gradient(circle, oklch(0.5 0.2 285), oklch(0.4 0.15 260) 50%, transparent 70%)"
    >
    </div>
    <div
      class="hero-glow-secondary absolute top-1/4 right-1/4 h-[500px] w-[500px] rounded-full opacity-12 blur-3xl"
      style="background: radial-gradient(circle, oklch(0.6 0.18 149), transparent 70%)"
    >
    </div>
    <!-- Grid pattern overlay -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(oklch(0.7 0.15 285) 1px, transparent 1px), linear-gradient(to right, oklch(0.7 0.15 285) 1px, transparent 1px); background-size: 60px 60px"
    ></div>
  </div>

  <div class="mx-auto max-w-4xl px-6 text-center">
    <!-- Version badge -->
    <div class="hero-fade-in mb-6 inline-flex items-center gap-2 rounded-full border border-border/60 bg-bg-surface/80 px-4 py-1.5 text-xs text-text-muted backdrop-blur-sm">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-green animate-pulse"></span>
      220,000+ lines of TypeScript &middot; 44 DB models &middot; 7 automation systems
    </div>

    <!-- Headline -->
    <h1 class="hero-fade-in text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="animation-delay: 0.1s">
      The self-hosted forex platform
      <br />
      <span class="bg-gradient-to-r from-accent via-blue to-indigo bg-clip-text text-transparent">
        that trades while you sleep
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-fade-in mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted sm:text-xl" style="animation-delay: 0.2s">
      AI-powered trade discovery, multi-agent debate analysis, autonomous execution, and real-time
      management — all running on your machine. Open source. Built with Claude Code.
    </p>

    <!-- Badges -->
    <div class="hero-fade-in mt-8 flex flex-wrap items-center justify-center gap-2" style="animation-delay: 0.3s">
      <a href="https://github.com/bmarshall511/forexflow/actions/workflows/ci.yml" target="_blank" rel="noopener noreferrer">
        <img src="https://github.com/bmarshall511/forexflow/actions/workflows/ci.yml/badge.svg" alt="CI" loading="lazy" />
      </a>
      <a href="https://github.com/bmarshall511/forexflow/actions/workflows/security.yml" target="_blank" rel="noopener noreferrer">
        <img src="https://github.com/bmarshall511/forexflow/actions/workflows/security.yml/badge.svg" alt="Security" loading="lazy" />
      </a>
      <img src="https://img.shields.io/badge/License-AGPL--3.0-blue.svg" alt="License: AGPL-3.0" loading="lazy" />
      <img src="https://img.shields.io/badge/TypeScript-5.7-blue.svg" alt="TypeScript" loading="lazy" />
    </div>

    <!-- CTAs -->
    <div class="hero-fade-in mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" style="animation-delay: 0.4s">
      <a
        href="#quickstart"
        class="group inline-flex items-center gap-2 rounded-xl bg-accent px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent/20 transition-all hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5"
      >
        Get Started
        <svg class="h-4 w-4 transition-transform group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
      <a
        href="https://github.com/bmarshall511/forexflow"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 rounded-xl border border-border bg-bg-surface px-7 py-3.5 text-sm font-semibold text-text transition-all hover:bg-bg-hover hover:border-border/80 hover:-translate-y-0.5"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Disclaimer -->
    <p class="hero-fade-in mt-14 text-xs leading-relaxed text-text-faint" style="animation-delay: 0.5s">
      ForexFlow is provided as-is for educational and personal use. It is not financial advice.
      Trading forex involves significant risk of loss. Use at your own risk.
    </p>
  </div>
</section>

<style>
  .hero-fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: heroFadeIn 0.6s ease-out forwards;
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-glow {
    animation: heroPulse 8s ease-in-out infinite alternate;
  }

  .hero-glow-secondary {
    animation: heroPulse 10s ease-in-out infinite alternate-reverse;
  }

  @keyframes heroPulse {
    from { opacity: 0.15; transform: translate(-50%, -50%) scale(0.95); }
    to { opacity: 0.28; transform: translate(-50%, -50%) scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade-in { opacity: 1; transform: none; animation: none; }
    .hero-glow, .hero-glow-secondary { animation: none; }
  }
</style>
