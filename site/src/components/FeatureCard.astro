---
interface Props {
  title: string
  description: string
  bullets: string[]
  icon: string
  color?: string
}

const { title, description, bullets, icon, color = "accent" } = Astro.props

const colorMap: Record<string, { bg: string; text: string }> = {
  accent: { bg: "bg-accent-subtle", text: "text-accent" },
  green: { bg: "bg-green-muted", text: "text-green" },
  amber: { bg: "bg-amber/10", text: "text-amber" },
  blue: { bg: "bg-blue/10", text: "text-blue" },
  indigo: { bg: "bg-indigo/10", text: "text-indigo" },
  red: { bg: "bg-red/10", text: "text-red" },
}

const colors = colorMap[color] ?? colorMap.accent
---

<div
  class="group rounded-xl border border-border bg-bg-surface p-6 transition-all duration-200 hover:border-border/60 hover:bg-bg-elevated hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/10"
>
  <!-- Icon -->
  <div class:list={["mb-4 inline-flex rounded-lg p-2.5", colors.bg]}>
    <Fragment set:html={icon} />
  </div>

  <!-- Title & description -->
  <h3 class="mb-2 text-lg font-semibold">{title}</h3>
  <p class="mb-4 text-sm leading-relaxed text-text-muted">{description}</p>

  <!-- Bullets -->
  <ul class="space-y-2">
    {
      bullets.map((bullet) => (
        <li class="flex items-start gap-2 text-sm text-text-muted">
          <svg
            class:list={["mt-0.5 h-4 w-4 shrink-0", colors.text]}
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{bullet}</span>
        </li>
      ))
    }
  </ul>
</div>
