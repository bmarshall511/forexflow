---
interface Props {
  currentPage?: string
}

const { currentPage = "home" } = Astro.props
const base = "/forexflow"

const navLinks = [
  { label: "Features", href: `${base}/#features` },
  { label: "Architecture", href: `${base}/#architecture` },
  { label: "AI Governance", href: `${base}/#governance` },
  { label: "Docs", href: `${base}/docs/` },
  { label: "API", href: `${base}/docs/api/` },
  { label: "Changelog", href: `${base}/changelog/` },
]
---

<nav
  id="site-nav"
  class="fixed top-0 right-0 left-0 z-50 border-b border-transparent transition-all duration-300"
  aria-label="Main navigation"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href={`${base}/`} class="flex items-center gap-2" aria-label="ForexFlow home">
      <img src={`${base}/logos/logo-white.png`} alt="ForexFlow" class="h-6" loading="eager" />
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-1 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-2 text-sm font-medium transition-colors hover:bg-bg-hover hover:text-text",
              currentPage === link.label.toLowerCase() ? "text-text" : "text-text-muted",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- GitHub CTA -->
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/bmarshall511/forexflow"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-lg border border-border bg-bg-surface px-4 py-2 text-sm font-medium text-text transition-colors hover:bg-bg-hover sm:flex"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        class="rounded-md p-2 text-text-muted transition-colors hover:bg-bg-hover hover:text-text md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border bg-bg-surface md:hidden">
    <div class="space-y-1 px-4 py-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block rounded-md px-3 py-2 text-sm font-medium text-text-muted transition-colors hover:bg-bg-hover hover:text-text"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com/bmarshall511/forexflow"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-md px-3 py-2 text-sm font-medium text-text-muted transition-colors hover:bg-bg-hover hover:text-text"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>

<script>
  // Sticky nav background on scroll
  const nav = document.getElementById("site-nav")
  if (nav) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          nav.classList.add("bg-bg/95", "backdrop-blur-md", "border-border")
          nav.classList.remove("border-transparent")
        } else {
          nav.classList.remove("bg-bg/95", "backdrop-blur-md", "border-border")
          nav.classList.add("border-transparent")
        }
      },
      { threshold: 0, rootMargin: "-64px 0px 0px 0px" },
    )
    // Observe a sentinel element at the top
    const sentinel = document.getElementById("hero-sentinel")
    if (sentinel) observer.observe(sentinel)
    else {
      // Fallback: always solid
      nav.classList.add("bg-bg/95", "backdrop-blur-md", "border-border")
    }
  }

  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn")
  const menu = document.getElementById("mobile-menu")
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden")
      btn.setAttribute("aria-expanded", String(!open))
    })
  }
</script>
