---
import SectionHeading from "./SectionHeading.astro"

const pillars = [
  {
    title: "CLAUDE.md",
    subtitle: "Project Constitution",
    description:
      "Loaded into every Claude Code session. Defines monorepo layout, strict import boundaries, coding standards, and critical domain concepts. The AI reads this before writing a single line of code.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>`,
  },
  {
    title: "11 Path-Scoped Rules",
    subtitle: ".claude/rules/",
    description:
      "Context-specific rules that auto-load based on which files the AI edits. TypeScript patterns, daemon architecture, accessibility standards, trading domain rules, desktop app conventions, and doc sync — each scoped to where they matter.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: "9 Reusable Skills",
    subtitle: ".claude/skills/",
    description:
      "Task templates for common operations. When the AI adds an API route, daemon endpoint, or WebSocket event, it follows a defined pattern — ensuring consistency across the entire codebase.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
]

const extras = [
  { label: "format-on-edit", desc: "Prettier runs on every file the AI edits" },
  { label: "guard-bash", desc: "Blocks destructive shell commands at execution time" },
  { label: "Sandbox", desc: "AI cannot read .env files or access secrets" },
]

const ruleExample = `# Claude Rule: Trading Domain

- Trade.source is always "oanda" — true origin in metadata.placedVia
- Use enrichSource() to map to display labels
- JPY pairs use 0.01 pip size, all others use 0.0001
- Market hours: Sun 5pm ET → Fri 5pm ET
- Daily rollover window: 4:59pm → 5:05pm ET`
---

<section id="governance" class="py-24" aria-label="AI Governance">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      title="AI governance that makes Claude Code production-ready"
      subtitle="A reusable pattern for any AI-assisted project. The .claude/ directory is why 221,000+ lines of AI-generated code are consistent and production-quality."
    />

    <!-- Three pillars -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        pillars.map((pillar) => (
          <div class="rounded-xl border border-border bg-bg-surface p-6">
            <div class="mb-3 inline-flex rounded-lg bg-accent-subtle p-2.5 text-accent">
              <Fragment set:html={pillar.icon} />
            </div>
            <h3 class="text-lg font-semibold">{pillar.title}</h3>
            <p class="mt-1 text-xs font-mono text-text-faint">{pillar.subtitle}</p>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">{pillar.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Code example -->
    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      <div>
        <h3 class="mb-4 text-lg font-semibold">Example: A path-scoped rule</h3>
        <div class="overflow-hidden rounded-xl border border-border bg-bg-elevated">
          <div class="flex items-center gap-2 border-b border-border px-4 py-2.5">
            <span class="h-3 w-3 rounded-full bg-red/60"></span>
            <span class="h-3 w-3 rounded-full bg-amber/60"></span>
            <span class="h-3 w-3 rounded-full bg-green/60"></span>
            <span class="ml-2 text-xs text-text-faint font-mono">.claude/rules/08-trading-domain.md</span>
          </div>
          <pre class="overflow-x-auto p-4 text-sm leading-relaxed text-text-muted font-mono"><code>{ruleExample}</code></pre>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-lg font-semibold">Automated safeguards</h3>
        <div class="space-y-4">
          {
            extras.map((extra) => (
              <div class="flex items-start gap-3 rounded-lg border border-border bg-bg-surface p-4">
                <div class="mt-0.5 rounded bg-accent-subtle p-1">
                  <svg
                    class="h-3.5 w-3.5 text-accent"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold">{extra.label}</p>
                  <p class="mt-0.5 text-sm text-text-muted">{extra.desc}</p>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Quote -->
        <blockquote class="mt-6 rounded-xl border-l-2 border-accent bg-accent-subtle/30 py-4 pr-4 pl-5">
          <p class="text-sm leading-relaxed text-text-muted italic">
            "The productivity gain from AI isn't 'it writes code faster.' It's that you can build a
            system where AI writes code that <span class="font-semibold text-text">fits the project</span> —
            every time, without re-explaining the project every time."
          </p>
        </blockquote>
      </div>
    </div>
  </div>
</section>
