---
const stats = [
  { value: "221K+", label: "Lines of TypeScript", detail: "strict mode" },
  { value: "114", label: "API Routes", detail: "Next.js handlers" },
  { value: "44", label: "Database Models", detail: "Prisma / SQLite" },
  { value: "363", label: "React Components", detail: "shadcn/ui based" },
  { value: "7", label: "Automation Systems", detail: "trading + AI" },
]
---

<section class="border-y border-border bg-bg-surface py-14" aria-label="Project statistics">
  <div class="mx-auto max-w-6xl px-6">
    <dl class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-5">
      {
        stats.map((stat) => (
          <div class="stat-item group text-center">
            <dd class="text-3xl font-bold tracking-tight font-mono bg-gradient-to-b from-text to-text-muted bg-clip-text text-transparent transition-colors group-hover:from-accent group-hover:to-blue">
              {stat.value}
            </dd>
            <dt class="mt-2 text-xs font-medium tracking-wider text-text-muted uppercase">
              {stat.label}
            </dt>
            <p class="mt-0.5 text-[10px] text-text-faint">{stat.detail}</p>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .stat-item {
    transition: transform 0.2s ease;
  }
  .stat-item:hover {
    transform: translateY(-2px);
  }
</style>
