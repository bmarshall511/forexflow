---
import Base from "./Base.astro"
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"

interface Props {
  title: string
  description?: string
  currentPage?: string
}

const { title, description, currentPage = "docs" } = Astro.props
const base = "/forexflow"

const sidebarLinks = [
  { group: "Getting Started", items: [
    { label: "Overview", href: `${base}/docs/` },
    { label: "Quick Start", href: `${base}/docs/#quickstart` },
    { label: "Configuration", href: `${base}/docs/#configuration` },
  ]},
  { group: "Architecture", items: [
    { label: "Monorepo Layout", href: `${base}/docs/#monorepo` },
    { label: "Signal Flow", href: `${base}/docs/#signal-flow` },
    { label: "Real-Time Patterns", href: `${base}/docs/#realtime` },
  ]},
  { group: "Features", items: [
    { label: "Dashboard", href: `${base}/docs/#dashboard` },
    { label: "TradingView Automation", href: `${base}/docs/#tv-alerts` },
    { label: "Trade Finder", href: `${base}/docs/#trade-finder` },
    { label: "AI Analysis", href: `${base}/docs/#ai-analysis` },
    { label: "AI Trader", href: `${base}/docs/#ai-trader` },
    { label: "Remote Access", href: `${base}/docs/#remote-access` },
  ]},
  { group: "Reference", items: [
    { label: "API Docs (TypeDoc)", href: `${base}/docs/api/` },
    { label: "Changelog", href: `${base}/changelog/` },
    { label: "Contributing", href: "https://github.com/bmarshall511/forexflow/blob/main/CONTRIBUTING.md" },
  ]},
]
---

<Base title={`${title} — ForexFlow Docs`} description={description}>
  <Nav currentPage={currentPage} />

  <div class="mx-auto flex max-w-7xl pt-20">
    <!-- Sidebar -->
    <aside class="sticky top-20 hidden h-[calc(100vh-5rem)] w-64 shrink-0 overflow-y-auto border-r border-border p-6 lg:block">
      <nav aria-label="Documentation navigation">
        {
          sidebarLinks.map((group) => (
            <div class="mb-6">
              <h3 class="mb-2 text-xs font-semibold tracking-wider text-text-faint uppercase">
                {group.group}
              </h3>
              <ul class="space-y-1">
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="block rounded-md px-3 py-1.5 text-sm text-text-muted transition-colors hover:bg-bg-hover hover:text-text"
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </aside>

    <!-- Main content -->
    <main class="min-w-0 flex-1 px-6 py-10 lg:px-12">
      <article class="prose-fxflow mx-auto max-w-3xl">
        <slot />
      </article>
    </main>
  </div>

  <Footer />
</Base>

<style is:global>
  /* Docs prose styling */
  .prose-fxflow h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }

  .prose-fxflow h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose-fxflow h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-fxflow p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .prose-fxflow a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-fxflow a:hover {
    color: var(--color-accent-hover);
  }

  .prose-fxflow code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-bg-elevated);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }

  .prose-fxflow pre {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose-fxflow pre code {
    background: none;
    padding: 0;
    font-size: 0.8125rem;
    line-height: 1.75;
  }

  .prose-fxflow ul,
  .prose-fxflow ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .prose-fxflow li {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .prose-fxflow ul li::marker {
    color: var(--color-accent);
  }

  .prose-fxflow table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .prose-fxflow th {
    text-align: left;
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose-fxflow td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border-subtle);
    color: var(--color-text-muted);
  }

  .prose-fxflow blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .prose-fxflow hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
</style>
