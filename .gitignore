*.swo

# ─── Claude Code (per-user state) ──────────────────────────────────────────
.claude/settings.local.json
.claude/.session-state/
# Use a glob (.../* ) rather than a directory ignore (.../) so the
# negations below can re-include README.md and .gitkeep. Git doesn't
# recurse into a fully-ignored directory, which would make negation
# rules no-ops. See FM-0004 / LRN-0006 / LRN-0007.
.claude/telemetry/*
!.claude/telemetry/.gitkeep
!.claude/telemetry/README.md
.claude/handoffs/*.md
!.claude/handoffs/README.md
!.claude/handoffs/latest.md
# Phase-boundary handoffs are durable reference artifacts — tracked
# so cold-start sessions can read them. Day-to-day mid-session
# handoffs stay per-user gitignored.
!.claude/handoffs/*-phase-*-complete.md
.claude/snapshots/*
!.claude/snapshots/README.md
!.claude/snapshots/phase-*.json
.claude/config/reserved-identifiers.json

# ─── Cursor (per-user state) ───────────────────────────────────────────────
.cursor/mcp.json

# ─── Misc ──────────────────────────────────────────────────────────────────
*.pem
.vercel
