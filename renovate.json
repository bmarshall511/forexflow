{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "group:monorepos", "group:recommended", ":semanticCommits"],
  "labels": ["deps"],
  "rangeStrategy": "bump",
  "schedule": ["after 9am on Monday"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "schedule": ["at any time"]
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["deps", "major"],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "prisma",
        "@prisma/client",
        "@prisma/adapter-libsql",
        "@prisma/engines"
      ],
      "groupName": "prisma",
      "automerge": false
    },
    {
      "matchPackageNames": ["next", "eslint-config-next", "@next/bundle-analyzer"],
      "groupName": "next.js",
      "automerge": false
    },
    {
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "react",
      "automerge": false
    },
    {
      "matchPackageNames": ["typescript"],
      "automerge": false
    },
    {
      "matchPackageNames": ["wrangler", "@cloudflare/workers-types"],
      "groupName": "cloudflare",
      "automerge": false
    }
  ]
}
