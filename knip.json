{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "apps/web": {
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/route.ts",
        "src/app/api/**/route.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/components/ui/**"]
    },
    "apps/daemons": {
      "project": ["src/**/*.ts"]
    },
    "apps/cf-worker": {
      "project": ["src/**/*.ts"]
    },
    "apps/mcp-server": {
      "project": ["src/**/*.ts"]
    },
    "packages/types": {
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "project": ["src/**/*.ts"]
    }
  }
}
